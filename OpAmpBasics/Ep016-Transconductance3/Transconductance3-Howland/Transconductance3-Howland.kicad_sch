  (text "Example 5 (revised): Howland with input buffer\n" (at 140.97 21.59 0)
    (effects (font (size 2.54 2.54)) (justify left bottom))
    (uuid 39c7b98b-8751-471f-a885-ca61af4badc1)
  )
  (text "R_{5}/R_{3} = R_{6}/R_{4}\nI_{out} = -V_{in}/R_{4}\n\n\"Textbook\" Howland current pump has poor voltage compliance and cannot\nbe scaled to large currents without substantial additional work (and\ninefficiency)."
    (at 17.78 191.77 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 876ed383-7c04-49f8-8db9-9e46ec4bbb9a)
  )
  (text "Example 5: Howland current pump" (at 25.4 21.59 0)
    (effects (font (size 2.54 2.54)) (justify left bottom))
    (uuid b4aa702c-fea6-4f05-8a45-08238df74911)
  )
  (text "* Initial demo is with a 0..1 kΩ load.\nVoltage compliance demos use a 0..10 kΩ load instead.\nData collection for spreadsheet analysis uses a\nsubstitution box instead of a pot for the load resistor."
    (at 99.06 161.29 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid caa4666d-6e47-40ad-8ffe-cf333ec3e2f1)
  )

